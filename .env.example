## Local dev configuration for root docker-compose.yml

# Database (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=proctoring_db
DATABASE_PORT=5434

# Redis
REDIS_PORT=6379

# Backend auth/session
JWT_SECRET_KEY=change_me_for_real_deployment
SECRET_KEY=change_me_for_real_deployment
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Networking / CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
STUDENT_FRONTEND_URL=http://localhost:5174
ADMIN_FRONTEND_URL=http://localhost:5173
WS_BASE_URL=ws://localhost:8080/ws

# MinIO (Storage)
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_for_real_deployment
MINIO_BUCKET_NAME=evidence-bucket
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Adminer (DB viewer)
ADMINER_PORT=8081

# Optional seeding
SEED_DEFAULT_USERS=true
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_me_for_real_deployment
