# Database
DB_TYPE=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=proctoring_db
DATABASE_HOST=db
DATABASE_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Auth / Session
JWT_SECRET_KEY=change_me_jwt_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
SEB_CONFIG_KEY=change_me_seb_config_key

# API / Networking
SERVER_HOST=0.0.0.0
PORT=8080
API_DOMAIN=api.example.com
WS_BASE_URL=wss://api.example.com/ws
CORS_ORIGINS=https://student.example.com,https://admin.example.com
STUDENT_FRONTEND_URL=https://student.example.com
ADMIN_FRONTEND_URL=https://admin.example.com

# Storage (MinIO / S3 compatible)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=change_me_minio_access_key
MINIO_SECRET_KEY=change_me_minio_secret_key
MINIO_BUCKET_NAME=evidence-bucket
MINIO_SECURE=false

# LTI
LTI_ISSUER=
LTI_CLIENT_ID=
LTI_AUTH_URL=
LTI_TOKEN_URL=
LTI_JWKS_URL=
LTI_PRIVATE_KEY=
LTI_PUBLIC_KEY=

# Optional seeding (disabled by default)
SEED_DEFAULT_USERS=false
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=System Admin
SEED_STUDENT_EMAIL=
SEED_STUDENT_PASSWORD=
SEED_STUDENT_NAME=Seeded Student
SEED_STUDENT_ROLL=SEED001
SEED_STUDENT_DEPARTMENT=Computer Science
